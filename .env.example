# agent-cc environment template.
#
# Copy to `.env` at the repo root and edit. The .env is loaded automatically by
# every service at startup (see packages/shared/src/env.ts). Real environment
# variables always win over this file. `.env` is gitignored; never commit secrets.
#
#   cp .env.example .env
#
# NOTE: this file is ONLY machine/runtime config (ports, paths, sockets).
# Operational config — LLM providers + API keys, personas, OAuth connections —
# is NOT set here. Those are created at runtime (Cmd-K in the dashboard, or the
# service APIs) and their secrets live encrypted in ~/.agent_cc/secrets.db, never
# in a file. See docs/plans/build-plan-v1.md.

# ---- Environment ----
# development | production | test
NODE_ENV=development
# trace | debug | info | warn | error | silent
LOG_LEVEL=info

# ---- Service ports (locked defaults; change only on a clash) ----
SUPERVISOR_PORT=7711
GATEWAY_PORT=7712
OAUTH_PORT=7713
PERSONA_PORT=7714
MEMORY_PORT=7715
DASHBOARD_PORT=3000

# ---- Storage (defaults under ~/.agent_cc/) ----
# Set AGENT_CC_HOME to relocate the whole data dir; the paths below default
# inside it. Override individual paths only if you need to split them.
AGENT_CC_HOME=
# AGENT_CC_DB_PATH=
# AGENT_CC_AUDIT_DB_PATH=
# AGENT_CC_SECRETS_DB_PATH=
# AGENT_CC_LOG_DIR=

# ---- tmux (the supervisor drives a dedicated, named server) ----
AGENT_CC_TMUX_SOCKET=agent-cc
AGENT_CC_TMUX_BIN=tmux

# ---- Agent sessions ----
# Default agent a new workspace launches. `claude` (Claude Code) authenticates
# via its own login and runs on YOUR CLAUDE SUBSCRIPTION — agent-cc makes no LLM
# API calls to run sessions. Set `bash` for a plain shell, or any agent CLI (aider).
AGENT_CC_DEFAULT_COMMAND=claude
# OPT-IN to per-token API billing instead of the subscription: set a key and it
# propagates into every agent session (claude/aider prefer it over the login).
# ANTHROPIC_API_KEY=
# Watchdog idle threshold / queue advance threshold (ms):
# AGENT_CC_IDLE_THRESHOLD_MS=5000
# AGENT_CC_QUEUE_IDLE_MS=12000

# ---- OAuth broker ----
# Max proxied operations per workspace per minute (default-deny scopes still apply).
OAUTH_RATE_LIMIT=120

# ---- Dashboard (browser) ----
# Baked at build time; the dashboard talks only to the supervisor.
NEXT_PUBLIC_SUPERVISOR_URL=http://localhost:7711
